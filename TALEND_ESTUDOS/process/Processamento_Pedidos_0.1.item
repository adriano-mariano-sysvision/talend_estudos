      <uiProperties/>
      <varTables sizeState="INTERMEDIATE" name="Var" minimized="true"/>
      <outputTables sizeState="INTERMEDIATE" name="out_pedidos">
        <mapperTableEntries name="id_pedidos" expression="row1.id_pedidos " type="id_String" nullable="true"/>
        <mapperTableEntries name="id_cliente" expression="row1.id_cliente " type="id_String" nullable="true"/>
        <mapperTableEntries name="nome_cliente" expression="row2.nome_cliente " type="id_String" nullable="true"/>
