        <mapperTableEntries name="valor_unitario" expression="row1.valor_unitario " type="id_BigDecimal" nullable="true"/>
        <mapperTableEntries name="valor_total" expression="new java.math.BigDecimal(row1.quantidade).multiply(row1.valor_unitario)" type="id_BigDecimal" nullable="true"/>
        <mapperTableEntries name="data_pedido" expression="row1.data_pedido " type="id_String" nullable="true"/>
        <mapperTableEntries name="status" expression="row1.status " type="id_String" nullable="true"/>
        <mapperTableEntries name="status_tratado" expression="row1.status.equals(&quot;Aprovado&quot;) ? &quot;Pedido Válido&quot; :&#xA;row1.status.equals(&quot;Pendente&quot;) ? &quot;Pedido em Análise&quot; :&#xA;row1.status.equals(&quot;Cancelado&quot;) ? &quot;Pedido Inválido&quot; :&#xA;&quot;Status Desconhecido&quot;" type="id_String" nullable="true"/>
        <mapperTableEntries name="cidade" expression="row2.cidade " type="id_String" nullable="true"/>
        <mapperTableEntries name="estado" expression="row2.estado " type="id_String" nullable="true"/>
